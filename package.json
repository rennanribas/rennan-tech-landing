{
  "name": "rennan-site",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "docker:build": "set -a; [ ! -f .env ] || . ./.env; set +a; docker build --platform=linux/amd64 -t ${ECR_REPOSITORY_URI:-rennan-site}:latest .",
    "docker:save": "set -a; [ ! -f .env ] || . ./.env; set +a; docker save ${ECR_REPOSITORY_URI:-rennan-site}:latest | gzip > /tmp/rennan-site.tar.gz",
    "docker:up": "docker network inspect lightsail-public >/dev/null 2>&1 || docker network create lightsail-public && docker compose up -d --force-recreate rennan-site",
    "dockeer:up": "pnpm run docker:up",
    "deploy:pull": "docker compose pull rennan-site",
    "deploy:up": "docker compose up -d --force-recreate rennan-site"
  },
  "dependencies": {
    "lucide-react": "^0.522.0",
    "motion": "^12.18.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.12.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^24.0.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react-swc": "^3.9.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.10",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.4.1",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "packageManager": "pnpm@10.28.2+sha512.41872f037ad22f7348e3b1debbaf7e867cfd448f2726d9cf74c08f19507c31d2c8e7a11525b983febc2df640b5438dee6023ebb1f84ed43cc2d654d2bc326264",
  "pnpm": {
    "overrides": {
      "qs": ">=6.14.1",
      "js-yaml": ">=4.1.1"
    }
  }
}
